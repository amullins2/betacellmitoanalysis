CELL_DIAM     = 100      # Cellpose diameter (pixels)
DUCT_CLUSTERS = [16, 24] # manually identified duct clusters (update if needed)

# ── Channel indices ───────────────────────────────────────────────────────
CH_VDAC1  = 0  # AF488
CH_MTCO1  = 1  # AF647
CH_INS    = 2  # AF405
