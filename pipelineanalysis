# =============================================================================

def main():
    print("=" * 60)
    print("Pancreatic Islet Analysis Pipeline")
    print("=" * 60)

    # 1. Load image
    channels = load_channels(TIFF_PATH)
    H, W     = channels['ecad'].shape

    # 2. Segment cells
    cells = run_tiled_segmentation(channels, OUTPUT_DIR)
    # OR load from checkpoint:
    # cells = pd.read_csv(OUTPUT_DIR / "all_cells_raw.csv")

    # 3. Classify beta cells
    cells, ins_thresh = classify_beta_cells(cells)

    # 4. Detect islets
    beta_cells, metrics_df = detect_islets(cells)
    valid_islets = metrics_df[
        ~metrics_df['cluster'].isin(DUCT_CLUSTERS)
    ].copy()
    print(f"Valid islets (after duct exclusion): {len(valid_islets)}")

