from sklearn.cluster import DBSCAN
from cellpose import models

# ── Configuration ─────────────────────────────────────────────────────────
TIFF_PATH  = "/path/to/your/image.tif"   # update this
OUTPUT_DIR = Path("/path/to/output/")     # update this
OUTPUT_DIR.mkdir(exist_ok=True)

PIXEL_UM      = 0.1235   # µm per pixel (20x LSM980)
TILE_SIZE     = 4000     # pixels per tile
