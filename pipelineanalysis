# =============================================================================
# SECTION 1: IMAGE LOADING
# =============================================================================

def load_channels(tiff_path):
    """Load 4-channel TIFF. Returns dict of channel arrays."""
    print("Loading image...")
    data = tifffile.imread(tiff_path)
    print(f"  Shape: {data.shape}")
    return {
        'vdac1':  data[CH_VDAC1],
        'mtco1':  data[CH_MTCO1],
        'insulin':data[CH_INS],
        'ecad':   data[CH_ECAD],
        'full':   data
    }


# =============================================================================
# SECTION 2: TILED CELLPOSE SEGMENTATION
# =============================================================================

def norm_cp(arr):
    """Normalise array to 0-255 uint8 using 1st-99.5th percentile."""
    mask = arr > 0
    if mask.sum() < 100:
        return arr.astype(np.uint8)
    lo = np.percentile(arr[mask], 1)
    hi = np.percentile(arr[mask], 99.5)
    return np.clip((arr - lo) / (hi - lo + 1e-8) * 255, 0, 255).astype(np.uint8)


def get_tiles(H, W, tile_size, overlap):
    """Generate tile coordinates covering full image."""
    tiles = []
    y = 0
    while y < H:
        x = 0
        while x < W:
            y1 = min(y + tile_size, H)
            x1 = min(x + tile_size, W)
            tiles.append((y, y1, x, x1))
            x += tile_size - overlap
        y += tile_size - overlap
    return tiles


def run_tiled_segmentation(channels, output_dir, 
                            tile_size=TILE_SIZE, overlap=OVERLAP):
    """
    Run Cellpose on full tissue image using tiled pipeline.
    
    Parameters
    ----------
    channels : dict — output of load_channels()
    output_dir : Path
    
    Returns
    -------
    cells : pd.DataFrame — per-cell measurements
    """
    ecad    = channels['ecad']
    insulin = channels['insulin']
    vdac1   = channels['vdac1']
    mtco1   = channels['mtco1']
    H, W    = ecad.shape

    # Load Cellpose model
    cell_model = models.CellposeModel(
        gpu=True, model_type='cyto3')

    tiles  = get_tiles(H, W, tile_size, overlap)
    BORDER = overlap // 2
    print(f"Total tiles: {len(tiles)}")

    all_cells      = []
    global_cell_id = 0

    import time
    start = time.time()

    for tile_idx, (y0, y1, x0, x1) in enumerate(tiles):

        # Skip empty tiles
        e_check = ecad[y0:y1:8, x0:x1:8]
        if (e_check > 5).sum() / e_check.size < 0.03:
            print(f"[{tile_idx+1:03d}/{len(tiles)}] SKIPPED (no tissue)")
            continue

        e_t = ecad[y0:y1, x0:x1].astype(np.float32)
        i_t = insulin[y0:y1, x0:x1].astype(np.float32)
        v_t = vdac1[y0:y1, x0:x1].astype(np.float32)
        m_t = mtco1[y0:y1, x0:x1].astype(np.float32)

        e_norm = norm_cp(e_t)
        i_norm = norm_cp(i_t)

        try:
            masks, _, _ = cell_model.eval(
                np.stack([e_norm, i_norm], axis=-1),
                diameter=CELL_DIAM,
                channel_axis=2,
                flow_threshold=0.8,
                cellprob_threshold=-1.0,
                augment=True,
                do_3D=False
            )
        except Exception as ex:
            print(f"  ERROR: {ex}")
            continue

        if masks.max() == 0:
            continue

        from skimage.measure import regionprops_table
        props = regionprops_table(
            masks,
            intensity_image=np.stack([e_t, i_t, v_t, m_t], axis=-1),
            properties=['label', 'area', 'centroid', 'bbox',
                        'intensity_mean', 'intensity_max']
        )
        df = pd.DataFrame(props)
        df.columns = [
            c.replace('intensity_mean-0', 'ecad_mean')
             .replace('intensity_mean-1', 'insulin_mean')
             .replace('intensity_mean-2', 'vdac1_mean')
             .replace('intensity_mean-3', 'mtco1_mean')
             .replace('intensity_max-0',  'ecad_max')
             .replace('intensity_max-1',  'insulin_max')
             .replace('intensity_max-2',  'vdac1_max')
             .replace('intensity_max-3',  'mtco1_max')
            for c in df.columns
        ]

        th, tw = masks.shape
        df = df[
            (df['centroid-0'] > BORDER) & 
            (df['centroid-0'] < th - BORDER) &
            (df['centroid-1'] > BORDER) & 
            (df['centroid-1'] < tw - BORDER)
        ].copy()

        df['y_fullres'] = df['centroid-0'] + y0
        df['x_fullres'] = df['centroid-1'] + x0
        df['cell_id']   = range(global_cell_id, 
                                 global_cell_id + len(df))
        df['tile_idx']  = tile_idx
        global_cell_id += len(df)
        all_cells.append(df)

        elapsed   = (time.time() - start) / 60
        rate      = elapsed / (tile_idx + 1)
        remaining = rate * (len(tiles) - tile_idx - 1)
        print(f"[{tile_idx+1:03d}/{len(tiles)}] "
              f"{masks.max()} detected, {len(df)} kept "
              f"| {elapsed:.0f}m elapsed | ~{remaining:.0f}m remaining")

        if (tile_idx + 1) % 10 == 0:
            ckpt = pd.concat(all_cells, ignore_index=True)
            ckpt.to_csv(output_dir / "cells_checkpoint.csv", index=False)
            print(f"  Checkpoint: {len(ckpt)} cells")

    cells = pd.concat(all_cells, ignore_index=True)
    cells.to_csv(output_dir / "all_cells_raw.csv", index=False)
    print(f"\\nSegmentation complete: {len(cells):,} cells in "
          f"{(time.time()-start)/60:.0f} minutes")
    return cells


# =============================================================================
# SECTION 3: BETA CELL CLASSIFICATION
# =============================================================================

def classify_beta_cells(cells):
    """
    Classify cells as beta cells using Otsu threshold on insulin intensity.
    
    Returns
    -------
    cells : pd.DataFrame with is_beta column
    ins_thresh : float
    """
    ins_thresh       = threshold_otsu(cells['insulin_mean'].values)
    cells['is_beta'] = cells['insulin_mean'] > ins_thresh
    print(f"Insulin threshold (Otsu): {ins_thresh:.2f}")
    print(f"Beta cells: {cells.is_beta.sum():,} / {len(cells):,} "
          f"({cells.is_beta.mean()*100:.1f}%)")
    return cells, ins_thresh


# =============================================================================
# SECTION 4: ISLET DETECTION
# =============================================================================

def detect_islets(cells, eps_px=200, min_samples=10):
    """
    Detect islet clusters using DBSCAN on insulin-positive cells.
    
    Parameters
    ----------
    eps_px      : int — max distance between beta cells in same islet (pixels)
    min_samples : int — minimum beta cells to form an islet
    
    Returns
    -------
    beta_cells : pd.DataFrame with islet_cluster column
    metrics_df : pd.DataFrame — per-islet shape metrics
    """
    beta_cells = cells[cells.is_beta].copy()
    coords     = beta_cells[['y_fullres','x_fullres']].values
    
    db     = DBSCAN(eps=eps_px, min_samples=min_samples, n_jobs=-1)
    labels = db.fit_predict(coords)
    beta_cells['islet_cluster'] = labels

    n_islets = len(set(labels)) - (1 if -1 in labels else 0)
    print(f"Islets detected: {n_islets}")
    print(f"Islet beta cells: {(labels>=0).sum():,}")
    print(f"Extra-islet candidates: {(labels==-1).sum():,}")

    # Compute per-cluster shape metrics
    stats_list = []
    for cl in sorted(set(labels)):
        if cl < 0:
            continue
        sub       = beta_cells[beta_cells.islet_cluster == cl]
        coords_cl = sub[['y_fullres','x_fullres']].values
        cy        = coords_cl[:,0].mean()
        cx        = coords_cl[:,1].mean()
        y_range   = coords_cl[:,0].max() - coords_cl[:,0].min()
        x_range   = coords_cl[:,1].max() - coords_cl[:,1].min()
        dists     = np.sqrt((coords_cl[:,0]-cy)**2 + (coords_cl[:,1]-cx)**2)
        ring_score = dists.std() / (dists.mean() + 1e-8)

        stats_list.append({
            'cluster':      cl,
            'n_cells':      len(sub),
            'centroid_y':   cy,
            'centroid_x':   cx,
            'diameter_um':  max(y_range, x_range) * PIXEL_UM,
            'ring_score':   ring_score,
            'mean_insulin': sub['insulin_mean'].mean()
        })

    metrics_df = pd.DataFrame(stats_list)
    return beta_cells, metrics_df


# =============================================================================
# SECTION 5: EXTRA-ISLET BETA CELL IDENTIFICATION
# =============================================================================

def identify_extraislet_beta_cells(beta_cells, cells, valid_islets,
                                    ins_thresh_pct=75,
                                    min_dist_um=150,
                                    contrast_min=4.0):
    """
    Identify truly isolated extra-islet beta cells using multi-criteria filter.
    
    Parameters
    ----------
    ins_thresh_pct : int   — insulin percentile threshold (islet beta cells)
    min_dist_um    : float — minimum distance from nearest islet (µm)
    contrast_min   : float — minimum insulin_max/insulin_mean ratio
    
    Returns
    -------
    truly_isolated : pd.DataFrame — validated extra-islet beta cells
    """
    # Get islet beta cell reference stats
    islet_beta = beta_cells[beta_cells.islet_cluster >= 0]
    ins_thresh  = np.percentile(islet_beta['insulin_mean'], ins_thresh_pct)
    size_min    = np.percentile(islet_beta['area'], 10)
    size_max    = np.percentile(islet_beta['area'], 95)
    print(f"Insulin threshold: {ins_thresh:.1f} AU "
          f"({ins_thresh_pct}th pct of islet beta cells)")
    print(f"Size range: {size_min:.0f} - {size_max:.0f} px²")

    # Candidate extra-islet cells
    extra = beta_cells[beta_cells.islet_cluster == -1].copy()
    extra['ins_contrast'] = extra['insulin_max'] / (extra['insulin_mean'] + 1e-8)

    # Distance to nearest islet
    islet_centroids = valid_islets[['centroid_y','centroid_x']].values
    extra_coords    = extra[['y_fullres','x_fullres']].values
    dists           = cdist(extra_coords, islet_centroids).min(axis=1)
    extra['min_dist_to_islet_um'] = dists * PIXEL_UM

    # Apply filters
    strict = extra[
        (extra['insulin_mean']         > ins_thresh) &
        (extra['min_dist_to_islet_um'] > min_dist_um) &
        (extra['area']                 >= size_min) &
        (extra['area']                 <= size_max) &
        (extra['ins_contrast']         >= contrast_min)
    ].copy()
    print(f"After filtering: {len(strict)} candidate cells")

    # Remove spatially grouped cells
    coords2  = strict[['y_fullres','x_fullres']].values
    db2      = DBSCAN(eps=150, min_samples=2, n_jobs=-1)
    labels2  = db2.fit_predict(coords2)
    isolated = strict[labels2 == -1].copy()
    print(f"Truly isolated: {len(isolated)} cells")
    print(f"Density: {len(isolated) / 5:.1f} cells/mm² "
          f"(literature: 17.3 cells/mm²)")
    return isolated


# =============================================================================
# SECTION 6: STATISTICAL ANALYSIS
# =============================================================================

def run_statistical_analysis(beta_cells, extra_final, duct_clusters):
    """
    Compare VDAC1, MTCO1/VDAC1, and Insulin between islet and 
    extra-islet beta cells using per-islet means.
    
    Returns
    -------
    islet_means : pd.DataFrame — per-islet mean values
    results     : dict — statistical test results
    """
    # Per-islet means (removes pseudoreplication)
    islet_beta = beta_cells[
        (beta_cells.islet_cluster >= 0) &
        (~beta_cells.islet_cluster.isin(duct_clusters))
    ].copy()
    islet_beta['mtco1_norm'] = (islet_beta['mtco1_mean'] / 
                                 (islet_beta['vdac1_mean'] + 1e-8))

    islet_means = islet_beta.groupby('islet_cluster').agg(
        vdac1_mean   = ('vdac1_mean',  'mean'),
        mtco1_mean   = ('mtco1_mean',  'mean'),
        mtco1_norm   = ('mtco1_norm',  'mean'),
        insulin_mean = ('insulin_mean','mean'),
        n_cells      = ('y_fullres',   'count')
    ).reset_index()

    extra_final = extra_final.copy()
    extra_final['mtco1_norm'] = (extra_final['mtco1_mean'] / 
                                  (extra_final['vdac1_mean'] + 1e-8))

    print("=" * 55)
    print("STATISTICAL RESULTS")
    print(f"Islet means:  n={len(islet_means)}")
    print(f"Extra-islet:  n={len(extra_final)}")
    print("=" * 55)

    results = {}
    for marker, name in [
        ('vdac1_mean',  'VDAC1'),
        ('mtco1_norm',  'MTCO1/VDAC1 ratio'),
        ('insulin_mean','Insulin'),
    ]:
        iv   = islet_means[marker].values
        ev   = extra_final[marker].values
        stat, pval = stats.mannwhitneyu(iv, ev, alternative='two-sided')
        sig  = ('***' if pval<0.001 else '**' if pval<0.01 
                else '*' if pval<0.05 else 'ns')
        results[name] = {
            'pval': pval, 'sig': sig,
            'islet_mean': iv.mean(), 'islet_std': iv.std(),
            'islet_median': np.median(iv),
            'extra_mean': ev.mean(), 'extra_std': ev.std(),
            'extra_median': np.median(ev)
        }
        print(f"\\n{name}:")
        print(f"  Islet:       {iv.mean():.3f} ± {iv.std():.3f} "
              f"(median={np.median(iv):.3f})")
        print(f"  Extra-islet: {ev.mean():.3f} ± {ev.std():.3f} "
              f"(median={np.median(ev):.3f})")
        print(f"  p={pval:.4f} {sig}")

    return islet_means, extra_final, results


